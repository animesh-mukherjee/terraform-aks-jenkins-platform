{
  "name": "platform-sample-app",
  "version": "1.0.0",
  "description": "Sample Node.js REST API demonstrating the AKS Jenkins CI/CD platform",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "mocha test/ --reporter spec --exit --timeout 5000",
    "test:ci": "mocha test/ --reporter mocha-junit-reporter --exit --timeout 5000",
    "lint": "eslint src/ test/ --ext .js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "eslint": "^8.55.0",
    "mocha": "^10.2.0",
    "mocha-junit-reporter": "^2.2.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
