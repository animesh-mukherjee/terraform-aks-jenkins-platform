// =============================================================================
// pipelines/Jenkinsfile.build
//
// Main CI/CD pipeline — triggered by Multibranch Pipeline on every push.
//
// Stage routing per CLAUDE.md architecture:
//   Stage 1  Checkout + Lint       [nodejs-agent, Node 2]
//   Stage 2  Unit Tests            [nodejs-agent, Node 2]
//   Stage 3  Docker Build + Push   [nodejs-agent + DinD sidecar, Node 2]
//   Stage 4  DB Migration (ACI)    [helm-agent, Node 2]
//   Stage 5  Helm Deploy → dev     [helm-agent, Node 2]
//   Stage 6  Smoke Test            [nodejs-agent, Node 2]
//   Stage 7  Service Bus Notify    [nodejs-agent, Node 2]
//   Stage 8  Approval Gate         [no agent — controller input()]
//   Stage 9  Helm Promote → staging [helm-agent, Node 2]
//
// Stages 8 + 9 are gated behind `when { branch 'main' }` — feature branches
// stop after Stage 7 (deliver to dev only, no staging promotion).
//
// Key Declarative Pipeline concepts used here:
//   agent none       — top-level: no persistent agent; each stage acquires its own
//   when { branch }  — conditional stage execution based on branch name
//   beforeAgent true — evaluate the `when` condition BEFORE allocating a pod agent
//                      (avoids spinning up a pod for stages that won't run)
//   input()          — pauses the pipeline waiting for a human approval click
//   catchError()     — marks stage UNSTABLE but continues the pipeline on failure
//   timeout()        — kills a hanging approval gate after 30 minutes
//   post { always }  — runs cleanWs() even when stages fail
// =============================================================================

pipeline {
  agent none

  options {
    buildDiscarder(logRotator(numToKeepStr: '10'))
    timeout(time: 60, unit: 'MINUTES')
    disableConcurrentBuilds()
    ansiColor('xterm')
    timestamps()
  }

  environment {
    // 8-char git commit SHA — used as the Docker image tag for full
    // traceability. GIT_COMMIT is set automatically by the Git SCM plugin.
    IMAGE_TAG = "${env.GIT_COMMIT[0..7]}"
    APP_NAME  = 'platform-sample-app'
  }

  stages {

    // -------------------------------------------------------------------------
    // Stage 1: Checkout + Lint
    // -------------------------------------------------------------------------
    stage('Checkout + Lint') {
      agent {
        kubernetes {
          label 'nodejs'
          defaultContainer 'nodejs'
        }
      }
      steps {
        checkout scm
        container('nodejs') {
          sh label: 'Install dependencies (cached)', script: '''
            cd app-sample
            npm ci --prefer-offline --no-audit
          '''
          sh label: 'ESLint', script: '''
            cd app-sample
            npm run lint
          '''
        }
      }
      post {
        failure {
          echo 'Lint failed. Run `npm run lint -- --fix` locally and re-push.'
        }
      }
    }

    // -------------------------------------------------------------------------
    // Stage 2: Unit Tests
    // -------------------------------------------------------------------------
    stage('Unit Tests') {
      agent {
        kubernetes {
          label 'nodejs'
          defaultContainer 'nodejs'
        }
      }
      steps {
        checkout scm
        container('nodejs') {
          sh label: 'Unit tests', script: '''
            cd app-sample
            npm ci --prefer-offline --no-audit
            npm test -- --reporter spec --exit 2>&1 | tee test-results.txt
          '''
        }
      }
      post {
        always {
          // JUnit XML reports are generated by the mocha-junit-reporter.
          // allowEmptyResults: true prevents this step from failing if no
          // XML is produced (e.g. tests were skipped).
          junit allowEmptyResults: true,
                testResults: 'app-sample/test-results/**/*.xml'
        }
      }
    }

    // -------------------------------------------------------------------------
    // Stage 3: Docker Build + Push to ACR
    // -------------------------------------------------------------------------
    // Two images are built: the app image and a migrations image.
    // Both are tagged with IMAGE_TAG (commit SHA) and `latest`.
    //
    // Docker CLI in the `nodejs` container connects to the `docker:dind`
    // sidecar via DOCKER_HOST=tcp://localhost:2375 (set in clouds.yaml).
    // The DinD container runs with privileged=true — required on AKS because
    // containerd (the node runtime) does not expose /var/run/docker.sock.
    stage('Docker Build + Push ACR') {
      agent {
        kubernetes {
          label 'nodejs'
          defaultContainer 'nodejs'
        }
      }
      steps {
        checkout scm
        container('nodejs') {
          withCredentials([
            usernamePassword(
              credentialsId: 'acr-credentials',
              usernameVariable: 'DOCKER_USER',
              passwordVariable: 'DOCKER_PASS'
            ),
            string(credentialsId: 'acr-login-server', variable: 'ACR_SERVER')
          ]) {
            sh label: 'Wait for Docker daemon (DinD warmup)', script: '''
              # DinD takes 2-5 s to initialise. Retry until docker info succeeds.
              for i in $(seq 1 15); do
                docker info >/dev/null 2>&1 && echo "Docker daemon ready." && break
                echo "Waiting for DinD sidecar... ($i/15)"
                sleep 2
              done
              docker info
            '''
            sh label: 'Log in to ACR', script: '''
              echo "$DOCKER_PASS" | \
                docker login "$ACR_SERVER" -u "$DOCKER_USER" --password-stdin
            '''
            sh label: 'Build app image', script: '''
              docker build \
                --build-arg BUILD_NUMBER="$BUILD_NUMBER" \
                --build-arg GIT_COMMIT="$GIT_COMMIT" \
                --tag "${ACR_SERVER}/${APP_NAME}:${IMAGE_TAG}" \
                --tag "${ACR_SERVER}/${APP_NAME}:latest" \
                --file app-sample/Dockerfile \
                app-sample/
            '''
            sh label: 'Build migrations image', script: '''
              docker build \
                --tag "${ACR_SERVER}/${APP_NAME}-migrations:${IMAGE_TAG}" \
                --tag "${ACR_SERVER}/${APP_NAME}-migrations:latest" \
                --file app-sample/db/Dockerfile.migrations \
                app-sample/
            '''
            sh label: 'Push both images to ACR', script: '''
              docker push "${ACR_SERVER}/${APP_NAME}:${IMAGE_TAG}"
              docker push "${ACR_SERVER}/${APP_NAME}:latest"
              docker push "${ACR_SERVER}/${APP_NAME}-migrations:${IMAGE_TAG}"
              docker push "${ACR_SERVER}/${APP_NAME}-migrations:latest"
            '''
            sh label: 'Docker logout', script: 'docker logout "$ACR_SERVER"'
          }
        }
      }
    }

    // -------------------------------------------------------------------------
    // Stage 4: DB Migration via ACI (one-shot Container Instance)
    // -------------------------------------------------------------------------
    // Replaces the ACI container group image with the migrations image built
    // in Stage 3, starts it, waits for it to terminate, then checks its exit
    // code. An exit code != 0 fails this stage and aborts the pipeline before
    // Helm deploys broken schema changes.
    //
    // The ACI was pre-provisioned by Terraform (modules/aci/) with:
    //   restart_policy = "Never"  — runs once and stops
    //   lifecycle.ignore_changes  — Terraform won't revert the image we set here
    //
    // ACI_NAME and RESOURCE_GROUP_NAME are injected from K8s Secret
    // jenkins-pipeline-creds (created by terraform/k8s-post/).
    stage('DB Migration (ACI)') {
      agent {
        kubernetes {
          label 'helm'
          defaultContainer 'helm'
        }
      }
      steps {
        container('helm') {
          withCredentials([
            usernamePassword(
              credentialsId: 'acr-credentials',
              usernameVariable: 'ACR_USER',
              passwordVariable: 'ACR_PASS'
            ),
            string(credentialsId: 'acr-login-server',            variable: 'ACR_SERVER'),
            string(credentialsId: 'postgresql-connection-string', variable: 'DB_CONN_STR')
          ]) {
            sh label: 'Run DB migration in ACI', script: '''
              set -euo pipefail

              # ── Parse PostgreSQL connection string ──────────────────────────
              # Format: postgresql://user:password@host:5432/dbname?sslmode=require
              DB_HOST=$(echo "$DB_CONN_STR" | \
                sed -n "s|.*://[^:]*:[^@]*@\\([^:]*\\):.*|\\1|p")
              DB_PORT=$(echo "$DB_CONN_STR" | \
                sed -n "s|.*:\\([0-9]*\\)/.*|\\1|p")
              DB_NAME=$(echo "$DB_CONN_STR" | \
                sed -n "s|.*/\\([^?]*\\).*|\\1|p")
              DB_USER=$(echo "$DB_CONN_STR" | \
                sed -n "s|.*://\\([^:]*\\):.*|\\1|p")
              DB_PASS=$(echo "$DB_CONN_STR" | \
                sed -n "s|.*://[^:]*:\\([^@]*\\)@.*|\\1|p")

              echo "Running migration against: ${DB_HOST}:${DB_PORT}/${DB_NAME}"

              # ── Delete previous ACI run (if any) ───────────────────────────
              # az container create is NOT idempotent when the group is in a
              # Terminated state — delete first to ensure a clean start.
              az container delete \
                --resource-group "$RESOURCE_GROUP_NAME" \
                --name           "$ACI_NAME" \
                --yes \
                --output none 2>/dev/null || true

              # ── Create new ACI run with migration image ────────────────────
              az container create \
                --resource-group          "$RESOURCE_GROUP_NAME" \
                --name                    "$ACI_NAME" \
                --image                   "${ACR_SERVER}/${APP_NAME}-migrations:${IMAGE_TAG}" \
                --restart-policy          Never \
                --os-type                 Linux \
                --cpu                     0.5 \
                --memory                  1 \
                --registry-login-server   "$ACR_SERVER" \
                --registry-username       "$ACR_USER" \
                --registry-password       "$ACR_PASS" \
                --environment-variables   \
                    DB_HOST="$DB_HOST"    \
                    DB_PORT="$DB_PORT"    \
                    DB_NAME="$DB_NAME"    \
                    DB_USER="$DB_USER"    \
                    DB_SSL=require        \
                --secure-environment-variables DB_PASSWORD="$DB_PASS" \
                --output none

              echo "Waiting for migration to complete (max 5 minutes)..."
              az container wait \
                --resource-group "$RESOURCE_GROUP_NAME" \
                --name           "$ACI_NAME" \
                --custom         "instanceView.state=='Terminated'" \
                --timeout        300

              # ── Check exit code ─────────────────────────────────────────────
              EXIT_CODE=$(az container show \
                --resource-group "$RESOURCE_GROUP_NAME" \
                --name           "$ACI_NAME" \
                --query          "containers[0].instanceView.currentState.exitCode" \
                --output         tsv 2>/dev/null || echo "1")

              # Print logs for debugging regardless of outcome
              echo "=== Migration container logs ==="
              az container logs \
                --resource-group "$RESOURCE_GROUP_NAME" \
                --name           "$ACI_NAME" \
                2>/dev/null || echo "(no logs available)"

              echo "Migration exit code: ${EXIT_CODE}"
              test "${EXIT_CODE}" = "0"
            '''
          }
        }
      }
    }

    // -------------------------------------------------------------------------
    // Stage 5: Helm Deploy → dev namespace
    // -------------------------------------------------------------------------
    // --atomic: if any resource fails to become ready within --timeout,
    // Helm performs an automatic rollback to the previous release version.
    // This prevents the dev environment from getting stuck in a broken state.
    stage('Helm Deploy (dev)') {
      agent {
        kubernetes {
          label 'helm'
          defaultContainer 'helm'
        }
      }
      steps {
        checkout scm
        container('helm') {
          withCredentials([
            string(credentialsId: 'acr-login-server', variable: 'ACR_SERVER')
          ]) {
            sh label: 'Helm upgrade --install → dev', script: '''
              helm upgrade --install "${APP_NAME}" \
                app-sample/helm/app-chart/ \
                --namespace      dev \
                --set            image.repository="${ACR_SERVER}/${APP_NAME}" \
                --set            image.tag="${IMAGE_TAG}" \
                --set            image.pullPolicy=IfNotPresent \
                --set            ingress.host="app.dev.platform.internal" \
                --values         app-sample/helm/app-chart/values.yaml \
                --wait \
                --timeout        5m \
                --atomic
            '''
          }
        }
      }
    }

    // -------------------------------------------------------------------------
    // Stage 6: Smoke Test
    // -------------------------------------------------------------------------
    // Hits the app's /health endpoint via the ClusterIP service name.
    // Using the internal service address (not the Ingress) makes the smoke
    // test independent of NGINX availability and DNS propagation.
    stage('Smoke Test') {
      agent {
        kubernetes {
          label 'nodejs'
          defaultContainer 'nodejs'
        }
      }
      steps {
        container('nodejs') {
          sh label: 'HTTP health check', script: '''
            set -euo pipefail
            MAX=15
            DELAY=5
            for i in $(seq 1 $MAX); do
              HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
                "http://${APP_NAME}.dev.svc.cluster.local:3000/health" \
                --max-time 5 2>/dev/null || echo "000")
              if [ "$HTTP_STATUS" = "200" ]; then
                echo "Smoke test PASSED (HTTP 200) on attempt $i"
                exit 0
              fi
              echo "Attempt $i/$MAX — got HTTP $HTTP_STATUS, retrying in ${DELAY}s..."
              sleep $DELAY
            done
            echo "Smoke test FAILED after $MAX attempts."
            exit 1
          '''
        }
      }
    }

    // -------------------------------------------------------------------------
    // Stage 7: Service Bus Notify
    // -------------------------------------------------------------------------
    // Publishes a build event to the Azure Service Bus build-events queue
    // using the SAS REST API (no SDK dependency — only Node.js stdlib).
    //
    // catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') means:
    //   - If the notification fails, the STAGE shows as UNSTABLE (yellow)
    //   - The overall BUILD result stays SUCCESS (green)
    //   - Pipeline continues to the Approval Gate
    // A notification failure must never block a deployment.
    stage('Service Bus Notify') {
      agent {
        kubernetes {
          label 'nodejs'
          defaultContainer 'nodejs'
        }
      }
      steps {
        container('nodejs') {
          catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
            withCredentials([
              string(credentialsId: 'service-bus-connection-string', variable: 'SB_CONN_STR')
            ]) {
              sh label: 'Publish build event (REST API + SAS token)', script: '''
                node --input-type=module << 'EOF'
// Node.js stdlib only — no npm install required in the agent container.
import crypto from 'crypto';
import https  from 'https';

// ── Parse connection string ─────────────────────────────────────────
// Format: Endpoint=sb://ns.servicebus.windows.net/;SharedAccessKeyName=...;SharedAccessKey=...
const parts = {};
for (const seg of process.env.SB_CONN_STR.split(';')) {
  const idx = seg.indexOf('=');
  if (idx > -1) parts[seg.slice(0, idx).trim()] = seg.slice(idx + 1).trim();
}
const namespace = parts['Endpoint'].replace('sb://', '').replace(/\/$/, '');
const keyName   = parts['SharedAccessKeyName'];
const key       = parts['SharedAccessKey'];
const queue     = 'build-events';

// ── Generate SAS token (valid 1 hour) ─────────────────────────────
const expiry   = Math.floor(Date.now() / 1000) + 3600;
const resource = encodeURIComponent(`https://${namespace}/${queue}`).toLowerCase();
const toSign   = `${resource}\n${expiry}`;
const sig      = encodeURIComponent(
  crypto.createHmac('sha256', key).update(toSign).digest('base64')
);
const token = `SharedAccessSignature sr=${resource}&sig=${sig}&se=${expiry}&skn=${keyName}`;

// ── Build message body ─────────────────────────────────────────────
const body = JSON.stringify({
  buildNumber : process.env.BUILD_NUMBER  || '0',
  jobName     : process.env.JOB_NAME      || 'unknown',
  branch      : process.env.BRANCH_NAME   || 'unknown',
  imageTag    : process.env.IMAGE_TAG     || 'unknown',
  gitCommit   : process.env.GIT_COMMIT    || 'unknown',
  status      : 'SUCCESS',
  timestamp   : new Date().toISOString(),
});

// ── POST to Service Bus REST endpoint ─────────────────────────────
await new Promise((resolve, reject) => {
  const req = https.request({
    hostname : namespace,
    path     : `/${queue}/messages`,
    method   : 'POST',
    headers  : {
      'Authorization'  : token,
      'Content-Type'   : 'application/json',
      'Content-Length' : Buffer.byteLength(body),
    },
  }, res => {
    const ok = res.statusCode >= 200 && res.statusCode < 300;
    console.log(`Service Bus response: ${res.statusCode} ${ok ? '(OK)' : '(FAILED)'}`);
    if (ok) resolve(); else reject(new Error(`HTTP ${res.statusCode}`));
  });
  req.on('error', reject);
  req.end(body);
});
console.log(`Build event published to queue: ${queue}`);
EOF
              '''
            }
          }
        }
      }
    }

    // -------------------------------------------------------------------------
    // Stage 8: Manual Approval Gate
    // -------------------------------------------------------------------------
    // Pauses here on the `main` branch only. Feature branches never reach
    // this stage — they stop after Stage 7 (dev deployment).
    //
    // `beforeAgent true` — the `when` condition is evaluated BEFORE Jenkins
    // tries to allocate a pod agent. Without this, a nodejs pod would spin up
    // on Node 2 just to be immediately released when the `when` condition
    // evaluates to false on a feature branch — wasteful.
    //
    // The input step runs on the controller (no agent needed). The controller
    // has numExecutors=0 but input() is special — it runs without consuming
    // an executor slot. Jenkins simply waits for a POST to its REST API.
    //
    // `submitter: 'admin'` — only the admin user can approve.
    // `submitterParameter: 'APPROVED_BY'` — captures the approver's username
    // as an env var, logged in the post-success step of Stage 9.
    stage('Approval Gate') {
      when {
        branch 'main'
        beforeAgent true
      }
      agent none
      steps {
        timeout(time: 30, unit: 'MINUTES') {
          input(
            message: "Promote build #${env.BUILD_NUMBER} (${env.IMAGE_TAG}) to staging?",
            ok:      'Yes, promote to staging',
            submitter: 'admin',
            submitterParameter: 'APPROVED_BY'
          )
        }
      }
    }

    // -------------------------------------------------------------------------
    // Stage 9: Helm Promote → staging namespace
    // -------------------------------------------------------------------------
    // Identical to Stage 5 but targets the `staging` namespace and uses
    // a staging-specific ingress hostname.
    stage('Helm Promote (staging)') {
      when {
        branch 'main'
        beforeAgent true
      }
      agent {
        kubernetes {
          label 'helm'
          defaultContainer 'helm'
        }
      }
      steps {
        checkout scm
        container('helm') {
          withCredentials([
            string(credentialsId: 'acr-login-server', variable: 'ACR_SERVER')
          ]) {
            sh label: 'Helm upgrade --install → staging', script: '''
              helm upgrade --install "${APP_NAME}" \
                app-sample/helm/app-chart/ \
                --namespace      staging \
                --set            image.repository="${ACR_SERVER}/${APP_NAME}" \
                --set            image.tag="${IMAGE_TAG}" \
                --set            image.pullPolicy=IfNotPresent \
                --set            ingress.host="app.staging.platform.internal" \
                --values         app-sample/helm/app-chart/values.yaml \
                --wait \
                --timeout        5m \
                --atomic
            '''
          }
        }
      }
      post {
        success {
          echo "Promoted ${env.IMAGE_TAG} to staging. Approved by: ${env.APPROVED_BY ?: 'N/A'}"
        }
      }
    }

  } // end stages

  post {
    always {
      // Workspace cleanup — prevents build artifacts (npm node_modules,
      // Docker layer caches) from filling the 10 Gi Jenkins PVC over time.
      cleanWs()
    }
    failure {
      echo "Pipeline FAILED at: ${env.STAGE_NAME}. Image tag: ${env.IMAGE_TAG}"
    }
    aborted {
      echo "Pipeline ABORTED (likely approval gate timeout). Image tag: ${env.IMAGE_TAG}"
    }
  }

}
